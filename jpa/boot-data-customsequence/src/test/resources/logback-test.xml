<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="info">
        <appender-ref ref="STDOUT"/>
    </root>

    <logger name="org.testcontainers" level="INFO"/>
    <logger name="com.github.dockerjava" level="WARN"/>
    <logger name="com.example.custom.sequence" level="DEBUG"/>
    <logger name="boot-data-jpa-customsequence-logger" level="DEBUG"/>
    <logger name="boot-data-jpa-customsequence-slow-logger" level="DEBUG"/>

</configuration>
